"""{{ project_name }} CLI entry point."""

import typer

app = typer.Typer(help="{{ project_name }} CLI tool")


@app.command("hello")
def hello(name: str = typer.Argument("world", help="Who to greet")):
    """Say hello."""
    typer.echo(f"Hello, {name}!")


@app.command("version")
def version():
    """Show version."""
    typer.echo("0.1.0")


if __name__ == "__main__":
    app()
