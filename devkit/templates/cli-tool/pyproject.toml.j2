[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.backends._legacy:_Backend"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "CLI tool generated by devkit"
requires-python = ">=3.10"
dependencies = [
    "typer>=0.9.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "pytest-cov>=4.0",
]

[project.scripts]
{{ project_kebab }} = "{{ project_slug }}.main:app"

[tool.setuptools.packages.find]
where = ["."]
include = ["{{ project_slug }}*"]
